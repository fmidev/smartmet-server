// Options

accesslogdir = "/var/log/smartmet/";

port 		= 8080;


// https support (SSL/TLS)

// self-signed certificate: openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -sha256 -days 365

encryption:
{
  enabled          = true;
  certificatefile  = "cert.pem";
  privatekeyfile   = "key.pem";
  passwordfile     = "password.txt";
  password         = "";
};


adminpool:
{
  maxthreads = 5;
  maxrequeuesize = 0;
};

slowpool:
{
  maxthreads = "50%";
  maxrequeuesize = 100;
};

fastpool:
{
  maxthreads = "100%";
  maxrequeuesize = 100;
};


lazylinking = false;

defaultlogging = true;

// Reverse-DNS (PTR) resolution of the client IP for diagnostics and the admin
// active-requests output. Resolution is cached (LRU, with separate positive and
// negative TTLs) and performed entirely off the request thread by background
// workers, so a slow or missing PTR record never delays request handling. Set
// dns.resolve = false to log the raw client IP only and skip lookups.

dns:
{
  resolve     = true;    // master switch
  cachesize   = 200000;  // max cached IP -> host name entries (LRU)
  positivettl = 3600;    // seconds a successful lookup stays cached
  negativettl = 60;      // seconds a failed lookup stays cached
  threads     = 1;       // number of background resolver threads
  maxqueuesize = 1000;   // max pending (queued + in-flight) lookups; excess is dropped
};

// Optional periodic logging of process memory usage to stdout. Disabled when
// logmemoryuse is 0 or absent. logmemoryfields selects which /proc/self/status
// fields are printed (default: RssAnon, RssFile). When jemalloc is the active
// allocator (typically injected via LD_PRELOAD in production), each line is also
// appended with jemalloc.{allocated,active,resident,mapped,retained} byte counts
// and jemalloc.fragmentation (external fragmentation percentage, (active-allocated)
// /active). jemalloc is resolved at runtime, so these fields are silently omitted
// when it is not preloaded (e.g. under libasan).

logmemoryuse    = 0;                          // logging period in minutes (0 = disabled)
logmemoryfields = ["RssAnon", "RssFile"];     // /proc/self/status fields to log

debug	       	= false;
verbose		= true;

engines:
{
	sputnik:
	{
	        configfile      = "/etc/smartmet/engines/sputnik.conf";
	};
	authentication:
	{
	        configfile      = "/etc/smartmet/engines/authentication.conf";
	};
	avi:
	{
	        configfile      = "/etc/smartmet/engines/avi.conf";
	};
	contour:
	{
	        configfile      = "/etc/smartmet/engines/contour.conf";
	};
	flash:
	{
	        configfile      = "/etc/smartmet/engines/flash.conf";
	};
	geonames:
	{
	        configfile      = "/etc/smartmet/engines/geonames.conf";
	};
	gis:
	{
	        configfile      = "/etc/smartmet/engines/gis.conf";
	};
	observation:
	{
	        configfile      = "/etc/smartmet/engines/observation.conf";
	};
	querydata:
	{
	        configfile      = "/etc/smartmet/engines/querydata.conf";
	};
};

plugins:
{
	backend:
	{
		disabled	= true;
		configfile	= "";
	};
	frontend:
	{
		disabled	= true;
		configfile	= "/etc/smartmet/plugins/frontend.conf";
	};
	admin:
	{
	        configfile      = "/etc/smartmet/plugins/admin.conf";
	};
	autocomplete:
	{
	        configfile      = "/etc/smartmet/plugins/autocomplete.conf";
	};
	avi:
	{
	        configfile      = "/etc/smartmet/plugins/avi.conf";
	};
	cross_section:
	{
	        configfile      = "/etc/smartmet/plugins/cross_section.conf";
	};
	download:
	{
	        configfile      = "/etc/smartmet/plugins/download.conf";
	};
	meta:
	{
	        configfile      = "/etc/smartmet/plugins/meta.conf";
	};
	observation:
	{
	        configfile      = "/etc/smartmet/plugins/observation.conf";
	};
	textgen:
	{
	        configfile      = "/etc/smartmet/plugins/textgen.conf";
	};
	timeseries:
	{
	        configfile      = "/etc/smartmet/plugins/timeseries.conf";
	};
	trajectory:
	{
	        configfile      = "/etc/smartmet/plugins/trajectory.conf";
	};
	wfs:
	{
	        configfile      = "/etc/smartmet/plugins/wfs.conf";
	};
	wms:
	{
	        configfile      = "/etc/smartmet/plugins/wms.conf";
	};
};


